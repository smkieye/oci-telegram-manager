# Telegram Bot Token from @BotFather
BOT_TOKEN=

# Comma/space separated Telegram numeric user IDs allowed to control OCI
ALLOWED_USER_IDS=6327047192

# Internal data directory inside container
DATA_DIR=/app/data

# Optional Cloudflare DNS automation
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ZONE_ID=
DEFAULT_CLOUDFLARE_RECORD=

# Web panel login. Set a strong password before exposing port 8080.
WEB_ADMIN_PASSWORD=
WEB_SESSION_SECRET=
